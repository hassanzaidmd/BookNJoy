# Server Configuration
PORT=5000

# MongoDB Database URI (Leave blank to use the in-memory fallback server)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/booknjoy?retryWrites=true&w=majority

# Allowed frontend origin(s), comma-separated if needed
FRONTEND_URL=https://book-n-joy.vercel.app

# JWT secret key for signature verification
JWT_SECRET=change_me_in_production
